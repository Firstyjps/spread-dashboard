# file: backend/.env.example
# Copy to .env and fill in your values

# === App Settings ===
APP_ENV=production
LOG_LEVEL=INFO

# === CORS (comma-separated origins) ===
# In production with nginx proxy, same-origin so CORS is not strictly needed.
# Set to your domain as a safety net.
CORS_ORIGINS=https://dash.firstyjps.com

# === Bybit ===
# Public market data does not require API keys
# For execution (future), uncomment:
# BYBIT_API_KEY=
# BYBIT_API_SECRET=
# api.bybit.com อาจถูกบล็อกโดย ISP ในไทย ใช้ api.bytick.com แทน (official alternative)
BYBIT_BASE_URL=https://api.bytick.com
BYBIT_WS_PUBLIC_LINEAR=wss://stream.bytick.com/v5/public/linear
BYBIT_WS_PUBLIC_SPOT=wss://stream.bytick.com/v5/public/spot

# === Lighter ===
# Public market data does not require API keys
# For execution (future), uncomment:
# LIGHTER_PRIVATE_KEY=
# LIGHTER_API_KEY_INDEX=
# LIGHTER_ACCOUNT_INDEX=
LIGHTER_BASE_URL=https://mainnet.zklighter.elliot.ai
LIGHTER_WS_URL=wss://mainnet.zklighter.elliot.ai/stream

# === Database ===
DB_PATH=./data/spread_dashboard.db

# === Symbols (comma-separated) ===
SYMBOLS=XAUTUSDT,HYPEUSDT

# === Alert Thresholds ===
SPREAD_ALERT_BPS=5.0
STALE_FEED_TIMEOUT_S=10
LATENCY_WARNING_MS=500

# === Polling ===
POLL_INTERVAL_MS=2000

# === Telegram Alerts ===
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALERT_COOLDOWN_S=60
ALERT_UPPER_BPS=9
ALERT_LOWER_BPS=-1
# Per-symbol overrides (format: SYMBOL:UPPER:LOWER,...)
# Symbols not listed here use the global defaults above
ALERT_OVERRIDES=
